{
  "name": "omnivox-dark-theme",
  "version": "1.0.0",
  "description": "Omnivox Dark Theme by majeurbilly",
  "author": "majeurbilly",
  "license": "MIT",
  "homepage": "https://github.com/majeurbilly/dark_omnivox",
  "packageManager": "pnpm@9.0.0",
  "engines": {
      "npm": "please-use-pnpm",
      "yarn": "please-use-pnpm"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/majeurbilly/dark_omnivox.git"
  },
  "scripts": {
    "build": "pnpm clean && pnpm typecheck && pnpm bundle && pnpm copy-assets",
    "bundle": "esbuild src/inject/inject.ts --bundle --format=iife --target=es2020 --outfile=dist/inject/content.js",
    "copy-assets": "tsx build.ts",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "lint": "biome check",
    "fix": "biome check --write"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.6",
    "@types/chrome": "^0.0.268",
    "@types/node": "^24.10.1",
    "esbuild": "^0.23.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3",
    "tsx": "^4.19.1"
  }
}