{
  "name": "__MSG_extensionName__",
  "version": "1.0.0",
  "manifest_version": 3,
  "description": "__MSG_extensionDescription__",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "default_locale": "en",
  "content_scripts": [
    {
      "matches": ["https://*.omnivox.ca/*"],
      "css": ["inject/inject.css"],
      "js": ["inject/content.js"],
      "run_at": "document_start",
      "exclude_matches": ["https://*.omnivox.ca/cvir/ddle/VisualiseDocument.aspx*"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject/icon.svg"],
      "matches": ["https://*.omnivox.ca/*"]
    }
  ],
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.omnivox.ca/*"
  ]
}
